{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@eden/domain/*": ["../../packages/domain/*"],
      "@eden/api/*": ["../../packages/api/*"],
      "@eden/ui/*": ["../../packages/ui/*"]
